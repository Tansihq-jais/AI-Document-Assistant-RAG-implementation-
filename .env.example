# AI Document Assistant - Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Optional: LLM Settings ────────────────────────────────────────────────────
OPENAI_MODEL=gpt-3.5-turbo        # Options: gpt-3.5-turbo, gpt-4, gpt-4o
TEMPERATURE=0.2                   # 0.0 = deterministic, 1.0 = creative
TOP_K=5                           # Number of chunks to retrieve per query

# ── Optional: Embedding Model ─────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternatives (larger/more accurate):
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Optional: Chunking ────────────────────────────────────────────────────────
CHUNK_SIZE=500                    # Words per chunk
CHUNK_OVERLAP=50                  # Overlap between consecutive chunks

# ── Optional: Storage ─────────────────────────────────────────────────────────
INDEX_DIR=./index_store           # Where FAISS index is persisted

# ── Optional: Server ──────────────────────────────────────────────────────────
PORT=8000
ENV=development                   # Set to 'production' to disable auto-reload
